{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/clu-governance-venv/bin/clu-governance",
            "args": [
              "claude-pretooluse",
              "--policy",
              "${CLAUDE_PROJECT_DIR}/.claude/clu-governance-policy.json"
            ],
            "timeout": 30
          }
        ]
      }
    ]
  }
}
